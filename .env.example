# Model provider: "openai-compatible", "anthropic", or "ollama".
HOYA_LLM_PROVIDER=openai-compatible

# OpenAI-compatible and Anthropic providers: API key is required.
# Ollama provider: leave this empty; Hoya will not send Authorization.
HOYA_API_KEY=replace_with_your_api_key

# Use the API endpoint, not the website homepage.
# Usually this ends with /v1. A full /v1/chat/completions URL is also accepted.
# Ollama local example: http://127.0.0.1:11434/v1
HOYA_BASE_URL=https://your-relay.example.com/v1
HOYA_MODEL=gpt-4o-mini

# Use "chat" for /chat/completions or "responses" for /responses.
# Anthropic is fixed to "messages" and uses /v1/messages.
# Ollama is fixed to "chat".
HOYA_WIRE_API=chat

# Anthropic direct API or Anthropic-compatible relay example:
# HOYA_LLM_PROVIDER=anthropic
# HOYA_API_KEY=replace_with_your_anthropic_api_key
# HOYA_BASE_URL=https://api.anthropic.com
# HOYA_MODEL=replace_with_an_available_claude_model
# HOYA_WIRE_API=messages

# Ollama local model example:
# HOYA_LLM_PROVIDER=ollama
# HOYA_API_KEY=
# HOYA_BASE_URL=http://127.0.0.1:11434/v1
# HOYA_MODEL=qwen2.5-coder:7b
# HOYA_WIRE_API=chat

# Set to 1 if you want the agent to run PowerShell commands in this workspace.
HOYA_ALLOW_SHELL=0

# Keep shell commands behind manual approval by default.
HOYA_REQUIRE_SHELL_APPROVAL=1

# Set to 1 if you want file writes to become pending diffs before they are applied.
HOYA_REQUIRE_WRITE_APPROVAL=0

# Set to 1 if you want the agent to create txt files on your Desktop.
HOYA_ALLOW_DESKTOP=0

# Optional generation and context settings.
# Reasoning effort: low, medium, high, xhigh, max.
HOYA_REASONING_EFFORT=medium

# Set to 0 to hide brief public reasoning/status summaries.
HOYA_SHOW_REASONING=1

HOYA_TEMPERATURE=0.2

# Local Ollama defaults are smaller when these are unset: steps=4, history=4,
# history chars=1200, tool result chars=4000. Override only if your model is fast enough.
HOYA_MAX_STEPS=8
HOYA_HISTORY_CONTEXT_LIMIT=12
HOYA_HISTORY_ENTRY_MAX_CHARS=4000
HOYA_TOOL_RESULT_MAX_CHARS=12000

# QQ / OneBot private chat bridge.
# Start with: python -m hoya_agent --qq
# Configure NapCat/Lagrange reverse HTTP URL to:
# http://127.0.0.1:8765/onebot
HOYA_QQ_HOST=127.0.0.1
HOYA_QQ_PORT=8765
HOYA_QQ_WEBHOOK_PATH=/onebot

# Required for inbound webhook validation.
# Send it as Authorization: Bearer <token> or X-Hoya-QQ-Token: <token>.
HOYA_QQ_WEBHOOK_TOKEN=replace_with_strong_random_token

# Required. Comma-separated QQ user IDs allowed to chat privately with Hoya.
HOYA_QQ_ALLOWED_USERS=123456789

# OneBot HTTP API endpoint used for send_private_msg.
HOYA_QQ_ONEBOT_API_URL=http://127.0.0.1:3000

# Optional but recommended if your OneBot HTTP API enables access token.
HOYA_QQ_ONEBOT_TOKEN=replace_with_onebot_access_token

HOYA_QQ_MAX_MESSAGE_CHARS=4000
HOYA_QQ_REPLY_CHUNK_CHARS=1500
HOYA_QQ_QUEUE_SIZE=1
HOYA_QQ_REQUEST_TIMEOUT=10
HOYA_QQ_SEND_STATUS=1

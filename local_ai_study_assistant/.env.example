# 服务配置
LSA_HOST=127.0.0.1
LSA_PORT=8008

# OpenAI-compatible Chat Completions 配置
# 不配置 LSA_API_KEY 时，系统仍可检索文档，但只返回相关片段，不调用大模型生成最终答案。
LSA_API_KEY=你的API_KEY
LSA_BASE_URL=https://api.openai.com/v1
LSA_MODEL=gpt-4o-mini

# 发送给大模型的最大上下文字数
LSA_MAX_CONTEXT_CHARS=6000

# Agent 可调用付费知识工具
# /api/ask 保持免费本地接口，/api/agent/ask 用于 Agent 调用和支付演示。
LSA_AGENT_TOOL_ENABLED=1
LSA_AGENT_MAX_QUESTION_CHARS=2000
LSA_AGENT_DEFAULT_TOP_K=5
LSA_AGENT_MAX_TOP_K=10

# 支付模式：off / mock / x402
# off：本地开发不校验支付；mock：用 X-Mock-Payment 或 JSON payment.token 演示 402 -> paid flow；x402：预留真实 GOAT/x402 校验边界。
LSA_PAYMENT_MODE=mock
LSA_PAYMENT_PRICE=$0.001
LSA_PAYMENT_ASSET=USDC
LSA_PAYMENT_NETWORK=base-sepolia
LSA_PAYMENT_RECIPIENT=replace_with_wallet_or_payment_address
LSA_PAYMENT_RESOURCE=/api/agent/ask
LSA_PAYMENT_MOCK_TOKEN=dev-paid
LSA_PAYMENT_TIMEOUT_SECONDS=30

# 可选：真实 x402 校验服务/网关确认后填入
LSA_X402_VERIFY_URL=
LSA_X402_API_KEY=

# Agent 付费端点调用记录
LSA_USAGE_LOG_PATH=data/usage.jsonl

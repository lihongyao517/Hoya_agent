{
  "name": "hoya-agent-desktop",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ../build_backend.ps1",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "test:electron": "node --test tests/*.test.cjs",
    "build": "npm run build:renderer",
    "pack": "npm run build:renderer && electron-builder --dir",
    "clean:old-artifacts": "node scripts/clean-old-artifacts.cjs",
    "dist": "npm run build:renderer && electron-builder && npm run clean:old-artifacts",
    "dist:full": "npm run build:backend && npm run dist",
    "release:github": "npm run build:backend && npm run build:renderer && electron-builder --publish always && npm run clean:old-artifacts",
    "start": "electron ."
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.14.3",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vue-tsc": "^3.3.7",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.hoya.agent.desktop",
    "productName": "Hoya Agent",
    "directories": {
      "output": "../artifacts/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../artifacts/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lihongyao517",
        "repo": "Hoya_agent",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "icon": "assets/icon.png",
    "nsis": {
      "artifactName": "Hoya-Agent-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hoya Agent"
    },
    "portable": {
      "artifactName": "Hoya-Agent-Portable-${version}-${arch}.${ext}"
    }
  }
}
